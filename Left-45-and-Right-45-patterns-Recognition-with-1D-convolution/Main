IMAGE_SIZE = (30, 30)
FLATTENED_IMAGE_LENGTH = IMAGE_SIZE[0] * IMAGE_SIZE[1]
NUM_CLASSES = 2
TRAIN_SAMPLES_PER_CLASS = 30000
TEST_SAMPLES_PER_CLASS = 6000
STRIPE_WIDTH = 2
GAP_WIDTH = 4
ACTIVATION_PROBABILITY = 0.85
NOISE_SIGMA = 0.45
CONV_KERNEL_SIZE = 3
BATCH_SIZE = 512
LEARNING_RATE = 1e-3
EPOCHS = 50
RANDOM_SEED = 42
DETERMINISTIC_WARN_ONLY = True

PLOT_FONTSIZE = 24
PLOT_DPI = 300
PLOT_PAD_INCHES = 0.35
PLOT_FONT_FAMILY = "Arial"

RESULT_ROOT = "1d_stripe_direction"
DATASET_PREVIEW_FILENAME = "stripe_dataset_class_examples.png"
COMPARE_CURVE_FILENAME = "stripe_direction_loss_accuracy_compare.png"
COMPARE_SUMMARY_FILENAME = "stripe_direction_comparison_summary.json"
PNG_EXPORT_DIRNAME = "png_examples_1d_45deg"

LABEL_NAMES = ["Class 1: Right45", "Class 2: Left45"]
DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")
PROGRESS_COLORS = {
    "symmetric": "green",
    "asymmetric": "blue",
}

